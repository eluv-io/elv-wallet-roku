<?xml version="1.0" encoding="UTF-8"?>
<component name="VideoPlayer" extends="BaseView" initialFocus="videoPlayer">
    <interface>
        <!-- A dict with propertyId and mediaId keys. And optionally a Title and isLive flag -->
        <field id="propertyMedia" type="assocArray" onChange="onPropertyMediaChanged" />
        <!-- Legacy MW v1 -->
        <field id="videoItem" type="assocArray" onChange="onVideoItemChanged" />
        <!-- Set to true by SGDEX ComponentController when this view is removed from the view stack -->
        <field id="wasClosed" type="boolean" onChange="onViewClosed" />
    </interface>
    <children>
        <Video id="videoPlayer" width="1920" height="1080" />
    </children>
</component>