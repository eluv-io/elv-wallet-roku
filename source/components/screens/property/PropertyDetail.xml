<?xml version="1.0" encoding="UTF-8"?>
<component name="PropertyDetail" extends="BaseView" initialFocus="rowList">
    <interface>
        <field id="property" type="assocArray" onChange="onPropertyChanged" />
        <!-- Can be used to view a property/page without a full object ready. -->
        <!-- Pass { propertyId: string, pageId: string|invalid } -->
        <field id="linkData" type="assocArray" onChange="onPageLinkChanged" />
    </interface>
    <children>
        <Poster id="bgImage" width="1920" height="1080" />
        <BusySpinner
            id="spinner"
            uri="pkg:/images/busyspinner_hd.png"
            translation="[920, 500]"
        />
        <ZoomRowList
            id="rowList"
            itemComponentName="SectionItem"
            rowDecorationComponentName='["SectionRow"]'
            spacingAfterRow="30"
            remainZoomedAboveFocus="never"
            fadeOutAboveFocus="never"
            showRowCounter="[false]"
            showRowTitle="[false]"
            useDefaultAspectRatio="[false]"
            wrap="false"
            translation="[96,0]"
        />
        <ActionButton
            id="btnSearch"
            translation="[1764, 66]"
            iconUri="pkg:/images/action_buttons/search.png"
            size="60"
            visible="false"
        />
        <!-- Only shown on Single Property (custom) builds, where there's no Dashboard -->
        <ActionButton
            id="btnProfile"
            translation="[1668, 66]"
            iconUri="pkg:/images/action_buttons/profile.png"
            size="60"
            visible="false"
        />
        <!-- Only shown on Single Property (custom) builds, where there's no Dashboard -->
        <ActionButton
            id="btnProfile"
            translation="[1668, 66]"
            iconUri="pkg:/images/tab_icons/profile.png"
            size="60"
            visible="false"
        />
    </children>
</component>